{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-lint.sh",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Auto-format and lint files after edits (ts/js/py/go/rs/md/json/yaml/sh)"
      }
    ]
  }
}
